# =====================================================================
# Celonis CI — environment template
# Copy to `.env` (gitignored) and fill in the values.
# =====================================================================

# === LLM providers ===
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.0
OPENAI_TIMEOUT=60
ANTHROPIC_API_KEY=

# === GEO / generative-search measurement ===
# Used by the GEO capability workflow alongside OpenAI.
PERPLEXITY_API_KEY=

# === Supabase (vector store + Postgres) ===
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Redis (ARQ task queue) ===
# Local: redis://localhost:6379
# Upstash: rediss://default:<token>@<host>:<port>
REDIS_URL=

# === Web scraping ===
FIRECRAWL_API_KEY=

# === Backend ===
# Comma-separated list of allowed CORS origins.
# Local:      BACKEND_CORS_ORIGINS=http://localhost:3000
# Production: BACKEND_CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
BACKEND_CORS_ORIGINS=http://localhost:3000

# === Auth ===
# APP_PASSWORD: min 12 chars — used for the single-user login endpoint.
# JWT_SECRET:   min 32 chars — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_PASSWORD=
JWT_SECRET=

# === Scraping / research (optional for basic runs) ===
FINNHUB_API_KEY=
SERPER_API_KEY=
BRANDFETCH_API_KEY=
BRANDFETCH_CLIENT_ID=
YOUTUBE_API_KEY=
GMAIL_APP_PASSWORD=

# === Frontend (Next.js) — set in frontend/.env.local ===
# Public env vars must start with NEXT_PUBLIC_ to be exposed to the browser.
# Local:      http://localhost:8000
# Production: https://your-backend.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# === Backend-only tooling ===
# OneDrive blocks uv's hard-linking; force copy mode. See backend/README.md.
UV_LINK_MODE=copy
